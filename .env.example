# .env.example — Copy to .env and fill in your values. DO NOT commit real secrets.

# Name of the Docker container to monitor
CONTAINER_NAME="your-container-name"

# Email credentials for sending alerts (use an app-specific password)
SENDER_EMAIL="your-email@example.com"
APP_PASSWORD="your-app-password-here"

# Comma-separated list of alert recipients (uncomment and edit as needed)
# ALERT_RECIPIENTS="admin@example.com,team@example.com"
ALERT_RECIPIENTS="your-primary-recipient@example.com"
WATCH_INTERVAL_SECONDS=60